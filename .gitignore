# Build output. Note: frontend/dist is required by the Go embed, so on
# a fresh clone run `wails build` (or create a stub file in dist)
# before `go test ./...`. CI does this in its workflows.
/build/bin/
/frontend/dist/

# Dependencies
/frontend/node_modules/

# Wails generated bindings are committed on purpose (frontend imports them),
# but the dev-only artifacts are not.
/frontend/wailsjs/runtime/runtime.d.ts.map

# Editor and OS noise
.DS_Store
Thumbs.db
*.log
