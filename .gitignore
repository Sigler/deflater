# Build output. dist keeps a committed placeholder so the Go embed
# compiles on a fresh clone; wails build fills in the real files.
/build/bin/
/frontend/dist/*
!/frontend/dist/.gitkeep

# Dependencies
/frontend/node_modules/

# Wails generated bindings are committed on purpose (frontend imports them),
# but the dev-only artifacts are not.
/frontend/wailsjs/runtime/runtime.d.ts.map

# Editor and OS noise
.DS_Store
Thumbs.db
*.log
